{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/workout", "destination": "/pages/workout.html" },
    { "source": "/body-parts", "destination": "/pages/body-parts.html" },
    { "source": "/diet", "destination": "/pages/diet-planner.html" },
    { "source": "/calculators", "destination": "/pages/nutrition-calculator.html" },
    { "source": "/community", "destination": "/pages/community.html" },
    { "source": "/trainers", "destination": "/pages/trainer-booking.html" },
    { "source": "/ai-coach", "destination": "/pages/ai-coach.html" },
    { "source": "/dashboard", "destination": "/pages/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|gif|png|svg|webp|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
