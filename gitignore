# ============================================================
# IRON EDGE FITNESS — .gitignore
# ============================================================

# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Firebase
.firebase/
firebase-debug.log
firebase-debug.*.log
ui-debug.log
firestore-debug.log
pubsub-debug.log
database-debug.log
.runtimeconfig.json

# Environment / secrets — never commit real service account keys
.env
.env.local
.env.*.local
*.pem
serviceAccountKey.json
# NOTE: js/firebase-config.js is intentionally NOT ignored — Firebase's
# client-side web config (apiKey, authDomain, etc.) is not a secret and
# must be committed/deployed for this static site to function, since
# there is no build step to inject it from environment variables.

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Build output (if a bundler is introduced later)
dist/
build/
.cache/

# Deployment platform caches
.vercel/
.netlify/
